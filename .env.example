# Printer interface — choose one:
# Ethernet (default):
PRINTER_INTERFACE=tcp://192.168.123.100:9100
# USB (uncomment to use USB instead):
# PRINTER_INTERFACE=printer:auto

# Used only when PRINTER_INTERFACE is not set (falls back to tcp)
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Gateway HTTP port
SERVER_PORT=3000

# Set to true to skip the real printer and log to console instead
MOCK_PRINTER=false

# Relay mode — gateway opens WSS to this host; app POSTs /scroll here too (see scroll-tracker-browser DEPLOYED_RELAY_BASE_URL)
USE_RELAY=true
RELAY_URL=https://infinite-scroll-relay-production.up.railway.app
# RELAY_URL=http://localhost:3001