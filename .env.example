# Printer interface — choose one:
# Ethernet (default):
PRINTER_INTERFACE=tcp://192.168.1.100:9100
# USB (Mac, printer plugged in via USB):
# PRINTER_INTERFACE=printer:auto
# USB with specific printer name:
# PRINTER_INTERFACE=printer:VRETTI_M817

# Used only when PRINTER_INTERFACE is not set (falls back to tcp)
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Gateway HTTP port
SERVER_PORT=3000

# Set to true to skip the real printer and log to console instead
MOCK_PRINTER=false
